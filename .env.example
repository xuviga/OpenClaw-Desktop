# OpenClaw Desktop Client Configuration

# Gateway connection
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18789
GATEWAY_TLS=false
GATEWAY_TOKEN=your_gateway_token_here

# Node identity
NODE_ID=
DISPLAY_NAME=

# Capabilities (comma-separated)
# Available: screenshot, clipboard, files, shell, system, ui_click, ui_type, notification
CAPABILITIES=screenshot,clipboard,files,shell,system,ui_click,ui_type,notification

# Screenshot settings
SCREENSHOT_INTERVAL_MS=10000
SCREENSHOT_FORMAT=png

# Clipboard settings
CLIPBOARD_INTERVAL_MS=5000

# System monitoring
SYSTEM_INTERVAL_MS=60000

# Reconnection
MAX_RECONNECT_ATTEMPTS=10
