{
  "name": "@openclaw/desktop-client",
  "version": "1.0.0",
  "description": "OpenClaw Desktop Client - Full remote control of your PC",
  "main": "main.js",
  "bin": {
    "openclaw-desktop": "./dist/cli.js"
  },
  "scripts": {
    "start": "electron .",
    "start:cli": "node dist/cli.js",
    "compile": "tsc",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win --x64",
    "build:mac": "tsc && electron-builder --mac",
    "build:linux": "tsc && electron-builder --linux",
    "pack": "electron-builder --dir",
    "clean": "rm -rf dist release"
  },
  "keywords": [
    "openclaw",
    "desktop",
    "remote",
    "control",
    "automation",
    "electron"
  ],
  "author": "OpenClaw",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.0.0",
    "electron": "33.4.11",
    "electron-builder": "^25.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.openclaw.desktop",
    "productName": "OpenClaw Desktop",
    "copyright": "Copyright © 2026 OpenClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "publisherName": "OpenClaw",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenClaw Desktop",
      "license": "LICENSE",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true,
      "displayLanguageSelector": false
    },
    "msi": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenClaw Desktop",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "maintainer": "OpenClaw"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    }
  }
}
